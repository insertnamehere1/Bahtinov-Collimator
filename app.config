<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <configSections>		
		<sectionGroup name="userSettings" type="System.Configuration.UserSettingsGroup, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" >
            <section name="Bahtinov_Collimator.Properties.Settings" type="System.Configuration.ClientSettingsSection, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" allowExeDefinition="MachineToLocalUser" requirePermission="false" />
        </sectionGroup>
    </configSections>
    <userSettings>
        <Bahtinov_Collimator.Properties.Settings>
            <setting name="VoiceEnabled" serializeAs="String">
                <value>False</value>
            </setting>
            <setting name="DefocusSwitch" serializeAs="String">
                <value>False</value>
            </setting>
            <setting name="SignChange" serializeAs="String">
                <value>False</value>
            </setting>
            <setting name="historyCount" serializeAs="String">
                <value>6</value>
            </setting>
            <setting name="ShowStartupCalibrationPrompt" serializeAs="String">
                <value>True</value>
            </setting>
            <setting name="CalibrationCompleted" serializeAs="String">
                <value>False</value>
            </setting>
            <setting name="SCTSelected" serializeAs="String">
                <value>True</value>
            </setting>
            <setting name="MCTSelected" serializeAs="String">
                <value>False</value>
            </setting>
            <setting name="NewtSelected" serializeAs="String">
                <value>False</value>
            </setting>
            <setting name="KeepOnTop" serializeAs="String">
                <value>False</value>
            </setting>
            <setting name="Minimize" serializeAs="String">
                <value>True</value>
            </setting>
            <setting name="MainWindowX" serializeAs="String">
                <value>-1</value>
            </setting>
            <setting name="MainWindowY" serializeAs="String">
                <value>-1</value>
            </setting>
        </Bahtinov_Collimator.Properties.Settings>
    </userSettings>

	<System.Windows.Forms.ApplicationConfigurationSection>
		<add key="DpiAwareness" value="PerMonitorV2" />
		<add key="EnableWindowsFormsHighDpiAutoResizing" value="false" />
	</System.Windows.Forms.ApplicationConfigurationSection>
	
</configuration>


